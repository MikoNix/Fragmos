# Force LF for shell scripts — prevents Windows CRLF breaking bash in WSL
*.sh        text eol=lf
*.bash      text eol=lf

# Python / config — also LF
*.py        text eol=lf
*.env       text eol=lf
*.toml      text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf

# Windows-native files — keep CRLF
*.bat       text eol=crlf
*.cmd       text eol=crlf

# Binaries — no conversion
*.png       binary
*.jpg       binary
*.db        binary
*.xml       binary
